# Token arbitrário (32 bytes hex) que você define e cola no painel do Meta
# durante a verificação inicial do webhook. Gere com:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
META_VERIFY_TOKEN=

# App Secret do seu App no Meta for Developers (Configurações → Básico → Mostrar).
# Usado pra validar a assinatura HMAC SHA-256 dos POSTs do Meta.
META_APP_SECRET=

# Page Access Token (idealmente "never expire") da Página do Facebook conectada
# ao formulário de Lead Ads. Usado pra buscar dados do lead na Graph API.
META_PAGE_ACCESS_TOKEN=
